{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix client install --legacy-peer-deps",
  "buildCommand": "npm --prefix client run build",
  "outputDirectory": "client/build",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://qv-training-library.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
